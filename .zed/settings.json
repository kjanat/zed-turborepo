{
  "formatter": [{ "external": { "command": "dprint", "arguments": ["fmt", "--stdin", "{buffer_path}"] } }],
  "prettier": { "allowed": false },
  "languages": { "TOML": { "wrap_guides": [120], "language_servers": ["tombi", "..."] } },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": { "allFeatures": true, "allTargets": true }
      }
    },
    "turbo-lsp": {
      "binary": {
        "path": "cargo",
        "arguments": [
          "run",
          "--bin",
          "turbo-lsp",
          "--manifest-path",
          "/home/kjanat/projects/zed-turborepo/crates/turbo-lsp/Cargo.toml"
        ]
      },
      "enable_lsp_tasks": true
    }
  },
  "context_servers": {
    "turbo-mcp": {
      "command": "cargo",
      "args": [
        "run",
        "--bin",
        "turbo-mcp",
        "--manifest-path",
        "/home/kjanat/projects/zed-turborepo/crates/turbo-mcp/Cargo.toml"
      ],
      "enabled": true
    }
  }
}
