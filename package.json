{
  "name": "zed-turborepo",
  "private": true,
  "workspaces": [
    "crates/*",
    "!vendor"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:release": "turbo run build:release",
    "check": "turbo run check",
    "clean": "turbo run clean",
    "fmt": "turbo run fmt",
    "install": "bun run install:lsp && bun run install:mcp",
    "install:lsp": "cargo install --path crates/turbo-lsp",
    "install:mcp": "cargo install --path crates/turbo-mcp",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/deno": "latest",
    "turbo": "^2.9.8"
  },
  "packageManager": "bun@1.3.13"
}
